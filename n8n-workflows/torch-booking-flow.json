      "id": "booking-webhook",
      "name": "New Booking Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 400],
      "webhookId": "torch-booking-flow"
    },
    {
      "parameters": {
        "jsCode": "// Process and validate booking data\nconst booking = $input.first().json;\n\n// Generate booking ID\nconst bookingId = `BK-${Date.now().toString(36).toUpperCase()}`;\n\n// Calculate duration in hours\nconst startTime = new Date(booking.startDateTime);\nconst endTime = new Date(booking.endDateTime);\nconst durationHours = (endTime - startTime) / (1000 * 60 * 60);\n\n// Format dates for display\nconst options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };\nconst timeOptions = { hour: 'numeric', minute: '2-digit', hour12: true };\n\nreturn {\n  bookingId,\n  memberId: booking.memberId,\n  memberName: booking.memberName,\n  memberEmail: booking.memberEmail,\n  memberPhone: booking.memberPhone,\n  spaceType: booking.spaceType || 'Main Studio',\n  startDateTime: booking.startDateTime,\n  endDateTime: booking.endDateTime,\n  startDateFormatted: startTime.toLocaleDateString('en-US', options),\n  startTimeFormatted: startTime.toLocaleTimeString('en-US', timeOptions),\n  endTimeFormatted: endTime.toLocaleTimeString('en-US', timeOptions),\n  durationHours,\n  eventType: booking.eventType || 'General',\n  expectedGuests: booking.expectedGuests || 0,\n  specialRequirements: booking.specialRequirements || '',\n  createdAt: new Date().toISOString(),\n  status: 'pending_validation'\n};"
      },
      "id": "process-booking",
      "name": "Process Booking Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.torchatl.com/internal/members/{{ $json.memberId }}/hours",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "get-member-hours",
      "name": "Get Member Hours",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [690, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "torch-api-credentials",
          "name": "TORCH Internal API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Validate booking against member hours\nconst booking = $input.first().json;\nconst memberHours = $('Get Member Hours').first().json;\n\nconst monthlyAllowance = memberHours.monthlyHours || 8;\nconst hoursUsed = memberHours.hoursUsed || 0;\nconst hoursRemaining = monthlyAllowance - hoursUsed;\nconst requestedHours = booking.durationHours;\n\nconst isValid = requestedHours <= hoursRemaining;\nconst requiresOverage = requestedHours > hoursRemaining && hoursRemaining > 0;\nconst overageHours = requiresOverage ? requestedHours - hoursRemaining : 0;\nconst overageRate = memberHours.overageRate || 75; // $ per hour\nconst overageCost = overageHours * overageRate;\n\nreturn {\n  ...booking,\n  validation: {\n    isValid: isValid || requiresOverage,\n    monthlyAllowance,\n    hoursUsed,\n    hoursRemaining,\n    requestedHours,\n    requiresOverage,\n    overageHours,\n    overageRate,\n    overageCost,\n    message: isValid \n      ? 'Booking approved within monthly allowance'\n      : requiresOverage \n        ? `Booking requires ${overageHours} overage hours at $${overageRate}/hr ($${overageCost} total)`\n        : 'Insufficient hours remaining'\n  },\n  status: (isValid || requiresOverage) ? 'validated' : 'rejected'\n};"
      },
      "id": "validate-hours",
      "name": "Validate Hours",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "validation-check",
              "leftValue": "={{ $json.validation.isValid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-validation",
      "name": "Is Booking Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1130, 400]
    },
    {
      "parameters": {
        "fromEmail": "bookings@torchatl.com",
        "toEmail": "={{ $json.memberEmail }}",
        "subject": "Booking Confirmed: {{ $json.spaceType }} on {{ $json.startDateFormatted }}",
        "emailType": "html",
        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #333; }\n    .header { background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%); padding: 30px; text-align: center; }\n    .header h1 { color: white; margin: 0; font-size: 28px; }\n    .content { padding: 30px; max-width: 600px; margin: 0 auto; }\n    .booking-details { background: #f8f8f8; border-radius: 8px; padding: 25px; margin: 20px 0; }\n    .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; }\n    .detail-label { color: #666; }\n    .detail-value { font-weight: bold; color: #333; }\n    .important-notice { background: #FFF3CD; border-left: 4px solid #FF6B35; padding: 15px; margin: 20px 0; }\n    .cta-button { display: inline-block; background: #FF6B35; color: white; padding: 12px 25px; text-decoration: none; border-radius: 5px; margin: 10px 5px; }\n    .footer { background: #333; color: #999; padding: 20px; text-align: center; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Booking Confirmed!</h1>\n  </div>\n  <div class=\"content\">\n    <p>Hi {{ $json.memberName }},</p>\n    <p>Your booking at TORCH ATL has been confirmed. Here are your details:</p>\n    \n    <div class=\"booking-details\">\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Booking ID</span>\n        <span class=\"detail-value\">{{ $json.bookingId }}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Space</span>\n        <span class=\"detail-value\">{{ $json.spaceType }}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Date</span>\n        <span class=\"detail-value\">{{ $json.startDateFormatted }}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Time</span>\n        <span class=\"detail-value\">{{ $json.startTimeFormatted }} - {{ $json.endTimeFormatted }}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Duration</span>\n        <span class=\"detail-value\">{{ $json.durationHours }} hours</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Expected Guests</span>\n        <span class=\"detail-value\">{{ $json.expectedGuests }}</span>\n      </div>\n    </div>\n    \n    <div class=\"important-notice\">\n      <strong>Important Reminders:</strong>\n      <ul>\n        <li>Guest list must be submitted 48 hours before your session</li>\n        <li>Arrive 15 minutes early for setup</li>\n        <li>Review our space guidelines in your member portal</li>\n      </ul>\n    </div>\n    \n    <p>\n      <a href=\"https://torchatl.com/bookings/{{ $json.bookingId }}\" class=\"cta-button\">View Booking</a>\n      <a href=\"https://torchatl.com/bookings/{{ $json.bookingId }}/guests\" class=\"cta-button\">Submit Guest List</a>\n    </p>\n    \n    <p>Need to make changes? Contact us at bookings@torchatl.com or reply to this email.</p>\n    \n    <p>See you soon!<br>\n    <strong>The TORCH ATL Team</strong></p>\n  </div>\n  <div class=\"footer\">\n    <p>TORCH ATL | Atlanta's Premier Creative Event Space</p>\n  </div>\n</body>\n</html>",
        "options": {}
      },
