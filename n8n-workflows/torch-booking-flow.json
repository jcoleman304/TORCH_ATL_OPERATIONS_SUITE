        "emailType": "html",
        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #333; }\n    .header { background: #FF6B35; padding: 25px; text-align: center; }\n    .header h1 { color: white; margin: 0; font-size: 24px; }\n    .content { padding: 30px; max-width: 600px; margin: 0 auto; }\n    .alert-box { background: #FFF3CD; border: 2px solid #FF6B35; border-radius: 8px; padding: 20px; margin: 20px 0; text-align: center; }\n    .cta-button { display: inline-block; background: #FF6B35; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; font-weight: bold; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Guest List Reminder</h1>\n  </div>\n  <div class=\"content\">\n    <p>Hi {{ $json.memberName }},</p>\n    \n    <div class=\"alert-box\">\n      <h2>Your session is in 48 hours!</h2>\n      <p><strong>{{ $json.startDateFormatted }}</strong><br>\n      {{ $json.startTimeFormatted }} - {{ $json.endTimeFormatted }}</p>\n    </div>\n    \n    <p><strong>Please submit your guest list now</strong> to ensure smooth check-in for your attendees.</p>\n    \n    <p>Expected guests: <strong>{{ $json.expectedGuests }}</strong></p>\n    \n    <p style=\"text-align: center;\">\n      <a href=\"https://torchatl.com/bookings/{{ $json.bookingId }}/guests\" class=\"cta-button\">Submit Guest List Now</a>\n    </p>\n    \n    <p>If you've already submitted your guest list, you can ignore this reminder.</p>\n    \n    <p>Questions? Reply to this email or contact us at bookings@torchatl.com</p>\n    \n    <p>Best,<br><strong>The TORCH ATL Team</strong></p>\n  </div>\n</body>\n</html>",
        "options": {}
