{
  "name": "Torch ATL - Master Orchestration",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "torch-master",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "master-webhook",
      "name": "Master Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 400],
      "webhookId": "torch-master-orchestration",
      "notes": "Central entry point for all TORCH events"
    },
    {
      "parameters": {
        "jsCode": "// Route incoming events to appropriate workflows\nconst event = $input.first().json;\n\n// Validate event structure\nif (!event.eventType) {\n  throw new Error('Missing eventType in request');\n}\n\nconst validEventTypes = [\n  'member.created',\n  'member.updated',\n  'member.suspended',\n  'member.reactivated',\n  'booking.created',\n  'booking.updated',\n  'booking.cancelled',\n  'booking.completed',\n  'payment.success',\n  'payment.failed',\n  'guest.registered',\n  'feedback.submitted',\n  'facility.issue',\n  'manual.trigger'\n];\n\nif (!validEventTypes.includes(event.eventType)) {\n  throw new Error(`Invalid eventType: ${event.eventType}. Valid types: ${validEventTypes.join(', ')}`);\n}\n\n// Determine target workflow based on event type\nconst eventCategory = event.eventType.split('.')[0];\nconst eventAction = event.eventType.split('.')[1];\n\nconst workflowMapping = {\n  'member': {\n    workflow: 'torch-member-onboarding',\n    webhookPath: 'torch-new-member'\n  },\n  'booking': {\n    workflow: 'torch-booking-flow',\n    webhookPath: event.eventType === 'booking.completed' ? 'torch-session-complete' : 'torch-new-booking'\n  },\n  'payment': {\n    workflow: 'torch-billing-automation',\n    webhookPath: 'torch-payment-event'\n  },\n  'guest': {\n    workflow: 'torch-booking-flow',\n    webhookPath: 'torch-guest-registration'\n  },\n  'feedback': {\n    workflow: 'torch-feedback-processor',\n    webhookPath: 'torch-feedback'\n  },\n  'facility': {\n    workflow: 'torch-daily-ops',\n    webhookPath: 'torch-facility-event'\n  },\n  'manual': {\n    workflow: event.targetWorkflow || 'torch-daily-ops',\n    webhookPath: event.targetWebhook || 'torch-manual-trigger'\n  }\n};\n\nconst routing = workflowMapping[eventCategory];\n\nreturn {\n  eventId: `evt_${Date.now().toString(36)}`,\n  eventType: event.eventType,\n  eventCategory,\n  eventAction,\n  targetWorkflow: routing.workflow,\n  targetWebhook: routing.webhookPath,\n  payload: event.data || event.payload || {},\n  metadata: {\n    source: event.source || 'unknown',\n    timestamp: new Date().toISOString(),\n    correlationId: event.correlationId || `corr_${Date.now().toString(36)}`,\n    priority: event.priority || 'normal'\n  },\n  retryCount: 0,\n  maxRetries: 3\n};"
      },
      "id": "route-event",
      "name": "Route Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
