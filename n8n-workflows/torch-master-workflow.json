      "id": "health-check-trigger",
      "name": "Hourly Health Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 1000],
      "notes": "Runs every hour to check system health"
    },
    {
      "parameters": {
        "jsCode": "// Perform health checks on all TORCH workflows\nconst workflows = [\n  { name: 'torch-member-onboarding', critical: true },\n  { name: 'torch-booking-flow', critical: true },\n  { name: 'torch-billing-automation', critical: true },\n  { name: 'torch-daily-ops', critical: false }\n];\n\nconst checks = [\n  { name: 'API Connectivity', endpoint: 'https://api.torchatl.com/health' },\n  { name: 'Database', endpoint: 'https://api.torchatl.com/health/db' },\n  { name: 'Email Service', endpoint: 'https://api.torchatl.com/health/email' },\n  { name: 'SMS Service', endpoint: 'https://api.torchatl.com/health/sms' },\n  { name: 'Payment Gateway', endpoint: 'https://api.torchatl.com/health/payments' }\n];\n\nreturn {\n  checkTime: new Date().toISOString(),\n  workflows,\n  healthChecks: checks\n};"
      },
      "id": "prepare-health-checks",
      "name": "Prepare Health Checks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 1000]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.torchatl.com/health",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 10000
        }
      },
      "id": "check-api-health",
      "name": "Check API Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [690, 1000],
      "credentials": {
        "httpHeaderAuth": {
          "id": "torch-api-credentials",
          "name": "TORCH Internal API"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Compile health check results\nconst apiHealth = $input.first().json;\nconst isHealthy = apiHealth.status === 'healthy' || apiHealth.status === 200;\n\nconst result = {\n  timestamp: new Date().toISOString(),\n  overallStatus: isHealthy ? 'healthy' : 'degraded',\n  services: {\n    api: {\n      status: isHealthy ? 'up' : 'down',\n      responseTime: apiHealth.responseTime || null,\n      lastChecked: new Date().toISOString()\n    },\n    database: apiHealth.database || { status: 'unknown' },\n    email: apiHealth.email || { status: 'unknown' },\n    sms: apiHealth.sms || { status: 'unknown' },\n    payments: apiHealth.payments || { status: 'unknown' }\n  },\n  alerts: []\n};\n\n// Generate alerts for any issues\nif (!isHealthy) {\n  result.alerts.push({\n    severity: 'critical',\n    message: 'API service is not responding',\n    timestamp: new Date().toISOString()\n  });\n}\n\nObject.entries(result.services).forEach(([service, data]) => {\n  if (data.status === 'down' || data.status === 'error') {\n    result.alerts.push({\n      severity: 'high',\n      message: `${service} service is down`,\n      timestamp: new Date().toISOString()\n    });\n  }\n});\n\nreturn result;"
      },
      "id": "compile-health-results",
      "name": "Compile Health Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 1000]
    },
