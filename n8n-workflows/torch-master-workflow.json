    {
      "parameters": {
        "jsCode": "// Compile weekly report\nconst data = $input.first().json;\nconst now = new Date();\nconst weekStart = new Date(now.setDate(now.getDate() - 7));\nconst weekEnd = new Date();\n\nreturn {\n  reportPeriod: {\n    start: weekStart.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }),\n    end: weekEnd.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })\n  },\n  members: {\n    total: data.totalMembers || 0,\n    new: data.newMembers || 0,\n    churned: data.churnedMembers || 0,\n    active: data.activeMembers || 0\n  },\n  bookings: {\n    total: data.totalBookings || 0,\n    completed: data.completedBookings || 0,\n    cancelled: data.cancelledBookings || 0,\n    noShows: data.noShows || 0,\n    utilizationRate: data.utilizationRate || 0\n  },\n  revenue: {\n    total: data.totalRevenue || 0,\n    membership: data.membershipRevenue || 0,\n    overage: data.overageRevenue || 0,\n    average: data.averageRevenue || 0\n  },\n  engagement: {\n    averageRating: data.averageRating || 0,\n    feedbackCount: data.feedbackCount || 0,\n    repeatBookings: data.repeatBookings || 0\n  },\n  topMembers: data.topMembers || [],\n  popularSpaces: data.popularSpaces || [],\n  insights: data.insights || []\n};"
      },
      "id": "compile-weekly-report",
      "name": "Compile Weekly Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 1300]
    },
    {
      "parameters": {
        "fromEmail": "reports@torchatl.com",
        "toEmail": "joi@torchatl.com",
        "subject": "TORCH ATL Weekly Report - {{ $json.reportPeriod.start }} to {{ $json.reportPeriod.end }}",
        "emailType": "html",
        "html": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #333; }\n    .header { background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%); padding: 40px; text-align: center; }\n    .header h1 { color: white; margin: 0; }\n    .content { padding: 30px; max-width: 700px; margin: 0 auto; }\n    .metric-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 30px 0; }\n    .metric-card { background: #f8f8f8; border-radius: 8px; padding: 25px; text-align: center; }\n    .metric-value { font-size: 36px; font-weight: bold; color: #FF6B35; }\n    .metric-label { color: #666; font-size: 14px; text-transform: uppercase; }\n    .section { margin: 30px 0; }\n    .section h2 { color: #333; border-bottom: 2px solid #FF6B35; padding-bottom: 10px; }\n    table { width: 100%; border-collapse: collapse; margin: 15px 0; }\n    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }\n    th { background: #f8f8f8; font-weight: bold; }\n    .insight { background: #E3F2FD; border-left: 4px solid #2196F3; padding: 15px; margin: 10px 0; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Weekly Performance Report</h1>\n    <p style=\"color: rgba(255,255,255,0.9);\">{{ $json.reportPeriod.start }} - {{ $json.reportPeriod.end }}</p>\n  </div>\n  \n  <div class=\"content\">\n    <div class=\"metric-grid\">\n      <div class=\"metric-card\">\n        <div class=\"metric-value\">{{ $json.bookings.total }}</div>\n        <div class=\"metric-label\">Total Bookings</div>\n      </div>\n      <div class=\"metric-card\">\n        <div class=\"metric-value\">${{ $json.revenue.total.toLocaleString() }}</div>\n        <div class=\"metric-label\">Revenue</div>\n      </div>\n      <div class=\"metric-card\">\n        <div class=\"metric-value\">{{ $json.members.new }}</div>\n        <div class=\"metric-label\">New Members</div>\n      </div>\n    </div>\n    \n    <div class=\"section\">\n      <h2>Member Summary</h2>\n      <table>\n        <tr><td>Total Members</td><td><strong>{{ $json.members.total }}</strong></td></tr>\n        <tr><td>Active This Week</td><td><strong>{{ $json.members.active }}</strong></td></tr>\n        <tr><td>New Sign-ups</td><td><strong>{{ $json.members.new }}</strong></td></tr>\n        <tr><td>Churned</td><td><strong>{{ $json.members.churned }}</strong></td></tr>\n      </table>\n    </div>\n    \n    <div class=\"section\">\n      <h2>Booking Performance</h2>\n      <table>\n        <tr><td>Completed Sessions</td><td><strong>{{ $json.bookings.completed }}</strong></td></tr>\n        <tr><td>Cancelled</td><td><strong>{{ $json.bookings.cancelled }}</strong></td></tr>\n        <tr><td>No-Shows</td><td><strong>{{ $json.bookings.noShows }}</strong></td></tr>\n        <tr><td>Utilization Rate</td><td><strong>{{ $json.bookings.utilizationRate }}%</strong></td></tr>\n      </table>\n    </div>\n    \n    <div class=\"section\">\n      <h2>Revenue Breakdown</h2>\n      <table>\n        <tr><td>Membership Revenue</td><td><strong>${{ $json.revenue.membership.toLocaleString() }}</strong></td></tr>\n        <tr><td>Overage Charges</td><td><strong>${{ $json.revenue.overage.toLocaleString() }}</strong></td></tr>\n        <tr><td>Average per Booking</td><td><strong>${{ $json.revenue.average.toFixed(2) }}</strong></td></tr>\n      </table>\n    </div>\n    \n    <div class=\"section\">\n      <h2>Customer Satisfaction</h2>\n      <table>\n        <tr><td>Average Rating</td><td><strong>{{ $json.engagement.averageRating.toFixed(1) }} / 5.0</strong></td></tr>\n        <tr><td>Feedback Received</td><td><strong>{{ $json.engagement.feedbackCount }}</strong></td></tr>\n        <tr><td>Repeat Bookings</td><td><strong>{{ $json.engagement.repeatBookings }}</strong></td></tr>\n      </table>\n    </div>\n    \n    {{ $json.insights.length > 0 ? '<div class=\"section\"><h2>Key Insights</h2>' + $json.insights.map(i => `<div class=\"insight\">${i}</div>`).join('') + '</div>' : '' }}\n    \n    <p style=\"text-align: center; margin-top: 40px;\">\n      <a href=\"https://torchatl.com/admin/analytics\" style=\"display: inline-block; background: #FF6B35; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; font-weight: bold;\">View Full Dashboard</a>\n    </p>\n  </div>\n</body>\n</html>",
        "options": {}
      },
