    {
      "parameters": {
        "jsCode": "// Process and categorize error\nconst error = $input.first().json;\n\nconst severity = categorizeError(error);\nconst shouldAlert = severity === 'critical' || severity === 'high';\n\nreturn {\n  errorId: `err_${Date.now().toString(36)}`,\n  timestamp: new Date().toISOString(),\n  workflow: error.workflow || 'unknown',\n  node: error.node || 'unknown',\n  message: error.message || 'Unknown error',\n  stack: error.stack || null,\n  severity,\n  shouldAlert,\n  context: error.context || {},\n  correlationId: error.correlationId || null\n};\n\nfunction categorizeError(err) {\n  const message = (err.message || '').toLowerCase();\n  \n  if (message.includes('payment') || message.includes('billing')) {\n    return 'critical';\n  }\n  if (message.includes('database') || message.includes('connection')) {\n    return 'critical';\n  }\n  if (message.includes('authentication') || message.includes('unauthorized')) {\n    return 'high';\n  }\n  if (message.includes('timeout') || message.includes('rate limit')) {\n    return 'medium';\n  }\n  return 'low';\n}"
      },
      "id": "process-error",
      "name": "Process Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 1600]
    },
    {
